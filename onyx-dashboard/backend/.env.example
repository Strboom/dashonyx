# ── Discord OAuth2 ──────────────────────────────────────────
# Create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# This MUST be added exactly in Discord Developer Portal → OAuth2 → Redirects
DISCORD_REDIRECT_URI=https://dashboard.onyxai.site/api/auth/discord/callback

# ── Session ─────────────────────────────────────────────────
# Any long random string — used to sign session cookies (keep secret!)
SESSION_SECRET=change_this_to_a_very_long_random_string_like_64_chars

# ── Bot Webhook Key ──────────────────────────────────────────
# Must match BOT_WEBHOOK_KEY in main.py exactly
BOT_WEBHOOK_KEY=onyx-bot-key-change-me

# ── Data Storage ─────────────────────────────────────────────
DASHBOARD_DATA_FILE=./dashboard_data.json

# ── (Optional) Bot Token ─────────────────────────────────────
# Add your bot token here to enable live channel & role fetching from Discord.
# Without this, channel/role pickers fall back to the user's OAuth token
# (which may not have access to all channels).
# BOT_TOKEN=your_bot_token_here

# ── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# The frontend is served by the same Express server in production,
# so FRONTEND_URL should be the same as your domain.
FRONTEND_URL=https://dashboard.onyxai.site
